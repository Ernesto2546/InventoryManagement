@model InventoryManagement.Models.Supplier

@{
    ViewData["Title"] = "Details";
}

<div class="page-header">
    <h1 class="page-title">
        <i class="bi bi-person-lines-fill me-2"></i>
        Supplier Details
    </h1>
</div>

    <div class="form-card">
        <div class="card-custom mb-4">
            <h4>Supplier</h4>
            <hr />

            <dl class="row">
                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Name)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Name)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Phone)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Phone)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Email)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Email)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Adress)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Adress)</dd>
            </dl>

            <div class="d-flex gap-2 mt-3">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                    <i class="bi bi-pencil-square me-1"></i> Edit
                </a>

                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                    <i class="bi bi-trash me-1"></i> Delete
                </a>

                <a asp-action="Index" class="btn btn-outline-secondary ms-auto">
                    <i class="bi bi-list-ul me-1"></i> Back to list
                </a>
            </div>
        </div>
    </div>
