<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - InventoryManagement</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/form-styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/InventoryManagement.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark shadow-sm bg-primary">
            <div class="container">

                <a class="navbar-brand fw-bold d-flex align-items-center"
                   asp-controller="Home"
                   asp-action="Index">

                    <i class="bi bi-box-seam-fill me-2 fs-4"></i>

                    InventoryPro
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbar">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div class="collapse navbar-collapse"
                     id="navbar">

                    <ul class="navbar-nav ms-auto align-items-center">

                        <li class="nav-item mx-2">
                            <a class="nav-link"
                               asp-controller="Home"
                               asp-action="Index">

                                <i class="bi bi-house-door me-1"></i>
                                Dashboard

                            </a>
                        </li>

                        <li class="nav-item mx-2">
                            <a class="nav-link"
                               asp-controller="Category"
                               asp-action="Index">

                                <i class="bi bi-bookmark-fill"></i>
                                Categories

                            </a>
                        </li>
                        <li class="nav-item mx-2">
                            <a class="nav-link"
                               asp-controller="Supplier"
                               asp-action="Index">

                                <i class="bi bi-person"></i>
                                Supplier

                            </a>
                        </li>
                        <li class="nav-item mx-2">
                            <a class="nav-link"
                               asp-controller=""
                               asp-action="Index">

                                <i class="bi bi-tags me-1"></i>
                                Products

                            </a>
                        </li>

                        <li class="nav-item mx-2">
                            <a class="nav-link"
                               asp-controller="Home"
                               asp-action="Privacy">

                                <i class="bi bi-shield-lock me-1"></i>
                                Privacy

                            </a>
                        </li>

                    </ul>

                </div>

            </div>
        </nav>
    </header>
    <main class="flex-fill container py-4" role="main">
        @RenderBody()
    </main>

    <footer class="bg-white border-top mt-auto footer">

        <div class="container py-3">

            <div class="d-flex justify-content-between align-items-center">

                <span class="text-muted">

                    © 2026 InventoryPro

                </span>

                <span class="text-muted">

                    ASP.NET Core MVC

                </span>

            </div>

        </div>

    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
