@model InventoryManagement.Models.Supplier

@{
    ViewData["Title"] = "Edit Supplier";
}

<div class="container py-4">

    <div class="page-header">
        <h1 class="page-title">
            <i class="bi bi-pencil-square me-2"></i>
            Edit Supplier
        </h1>
    </div>

    <div class="row justify-content-center">

        <div class="col-lg-8 col-xl-7">

            <form asp-action="Edit" class="form-card">

                <div class="card-custom mb-4">

                    <h4 class="mb-1">
                        Supplier Information
                    </h4>

                    <p class="text-muted mb-4">
                        Update the supplier information below.
                    </p>

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <input type="hidden" asp-for="Id" />

                    <div class="row g-4">

                        <div class="col-md-6">

                            <label asp-for="Name" class="form-label"></label>

                            <input asp-for="Name" class="form-control" />

                            <span asp-validation-for="Name" class="text-danger small"></span>

                        </div>

                        <div class="col-md-6">

                            <label asp-for="Phone" class="form-label"></label>

                            <input asp-for="Phone" class="form-control" />

                            <span asp-validation-for="Phone" class="text-danger small"></span>

                        </div>

                        <div class="col-md-6">

                            <label asp-for="Email" class="form-label"></label>

                            <input asp-for="Email" class="form-control" />

                            <span asp-validation-for="Email" class="text-danger small"></span>

                        </div>

                        <div class="col-md-6">

                            <label asp-for="Adress" class="form-label"></label>

                            <input asp-for="Adress" class="form-control" />

                            <span asp-validation-for="Adress" class="text-danger small"></span>

                        </div>

                    </div>

                </div>

                @{
                    ViewData["SubmitText"] = "Save Changes";
                    ViewData["CancelAction"] = "Index";
                }

                @await Html.PartialAsync("_FormButtons")

            </form>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}