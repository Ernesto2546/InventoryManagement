@{
    var submitText = ViewData["SubmitText"] as string ?? "Save";
    var cancelAction = ViewData["CancelAction"] as string ?? "Index";
    var buttonClass = ViewData["ButtonClass"] as string ?? "btn btn-primary btn-primary-custom";
    bool showCancel = true;
    if (ViewData.ContainsKey("ShowCancel") && ViewData["ShowCancel"] is bool sc)
    {
        showCancel = sc;
    }
}

<div class="form-actions d-flex justify-content-center gap-4 mt-6">
    <button type="submit" class="@buttonClass">
        <i class="bi bi-check2-circle me-1"></i> @submitText
    </button>

    @if (showCancel)
    {
        <a asp-action="@cancelAction" class="btn btn-outline-secondary">
            <i class="bi bi-x-circle me-1"></i> Cancel
        </a>
    }
</div>
